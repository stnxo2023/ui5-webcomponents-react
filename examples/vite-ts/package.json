    "react-dom": "19.2.7",
    "react-router": "8.1.0"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@ui5/webcomponents-cypress-commands": "2.24.1",
    "@vitejs/plugin-react": "6.0.3",
    "cypress": "15.18.0",
    "eslint": "9.39.4",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
