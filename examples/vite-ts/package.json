{
  "name": "vite-ts",
  "description": "UI5 Web Components for React - Vite + TypeScript example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "cypress run --component --browser chrome",
